#!/usr/bin/env bash
# shellcheck disable=SC2154
# Configure Nginx to return a custom X-Served-By header with the host name

set -e

CONF="/etc/nginx/sites-available/default"

# Install Nginx
sudo apt-get update -y >/dev/null
sudo apt-get install -y nginx >/dev/null

# Ensure header is present exactly once in the default server block
sudo sed -i '/add_header X-Served-By/d' "$CONF"
sudo sed -i '/server_name _;/a \    add_header X-Served-By $hostname always;' "$CONF"

# Restart Nginx to apply changes
sudo service nginx restart >/dev/null

#!/usr/bin/env bash
# Install and configure HAProxy

apt-get update -y
apt-get install -y haproxy

sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/haproxy

cat <<EOF > /etc/haproxy/haproxy.cfg
global
    log /dev/log local0
    log /dev/log local1 notice
    maxconn 2000
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    retries 3
    option redispatch
    timeout connect 5000
    timeout client  50000
    timeout server  50000

frontend http_front
    bind *:80
    default_backend web_servers

backend web_servers
    balance roundrobin
    server 7046-web-01 3.83.153.109:80 check
    server 7046-web-02 13.218.53.237:80 check

listen stats
    bind *:8404
    stats enable
    stats uri /haproxy?stats
EOF

service haproxy restart

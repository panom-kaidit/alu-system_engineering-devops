#!/usr/bin/env bash
# This script starts Apache in the running container and sets the Hello Holberton page

# Get the running container ID for the given image
CONTAINER_ID=$(docker ps -q --filter "ancestor=holbertonschool/265-0")

# Check if container exists
if [ -z "$CONTAINER_ID" ]; then
    echo "No running container found for holbertonschool/265-0"
    exit 1
fi

# Start Apache inside the container
docker exec "$CONTAINER_ID" service apache2 start

# Create the required page
docker exec "$CONTAINER_ID" bash -c 'echo "Hello Holberton" > /var/www/html/index.html'

echo "Apache started and page configured successfully."
#!/usr/bin/env bash
# This script configures Nginx to listen on port 80 and starts the service

# Ensure Nginx listens on port 80 on all IPv4 addresses
sed -i 's/listen .*/listen 80 default_server;/' /etc/nginx/sites-available/default
sed -i 's/listen \[::\].*/listen [::]:80 default_server;/' /etc/nginx/sites-available/default

# Restart Nginx service
service nginx restart